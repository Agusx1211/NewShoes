{
  "name": "cnc-generals-wasm",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "bash tools/build_wasm.sh",
    "clean:wasm": "bash tools/clean_wasm.sh",
    "extract:real-big": "bash tools/extract_zh_big_sample.sh",
    "extract:runtime-archives": "bash tools/extract_zh_runtime_archives.sh",
    "verify:assets": "node tools/verify_real_assets.mjs",
    "serve:harness": "node harness/serve.mjs",
    "test:all": "npm run build:wasm && node dist/compression-eac-smoke.cjs && node dist/wwdebug-core-smoke.cjs && node dist/wwlib-sha-smoke.cjs && node dist/wwmath-core-smoke.cjs && EXPECT_WASM=1 node harness/smoke.mjs",
    "test:compression-eac": "npm run build:wasm && node dist/compression-eac-smoke.cjs",
    "test:refpack": "npm run test:compression-eac",
    "test:wwdebug-core": "npm run build:wasm && node dist/wwdebug-core-smoke.cjs",
    "test:wwlib-sha": "npm run build:wasm && node dist/wwlib-sha-smoke.cjs",
    "test:wwmath-core": "npm run build:wasm && node dist/wwmath-core-smoke.cjs",
    "test:harness": "node harness/smoke.mjs",
    "test:wasm": "npm run build:wasm && EXPECT_WASM=1 node harness/smoke.mjs"
  },
  "devDependencies": {
    "playwright": "1.61.0"
  }
}
